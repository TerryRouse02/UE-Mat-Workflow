node_modules/
dist/
*.log
.DS_Store
.vite/
coverage/

# TypeScript incremental build cache (regenerated on every build)
*.tsbuildinfo

# tsc -b emitted artifacts that shouldn't live next to source
viewer/web/src/**/*.js
viewer/web/src/**/*.d.ts
!viewer/web/src/vite-env.d.ts

# AI-output graphs (not curated examples — those live in agent-pack/examples/)
graphs/*.matgraph.json
graphs/**/*.matgraph.json
!graphs/.gitkeep
# Exception: the all-nodes stress material is version-controlled (export regression artifact)
!graphs/stress_all_nodes/*.matgraph.json
# Exception: the paste-safe common-nodes stress material is version-controlled (round-trip regression artifact)
!graphs/stress_common/*.matgraph.json

# Unreal Engine scratch
/Temp

# Windows debug symbols (e.g. UE plugin builds — keep the .dll, drop the symbols)
*.pdb

# Editor / IDE settings
.vscode/
.idea/
*.iml
*.suo

# Environment files
.env
.env.local
.env.*.local

# Local-only work-project Material Function index (the user's OWN project MFs).
# Generated by the WorkMF crawl; never committed, never bundled into the web build.
# The *.example.json alongside is committed on purpose (schema reference).
agent-pack/workmf-index.json
agent-pack/workmf-index.export.json

# Local-only staged project material/MF T3D files. Generated by the ProjectMat
# crawl before the viewer imports them into gitignored graphs/_project/.
tools/node-t3d-metadata/projectmat-staging/

# Per-machine tooling config (project/engine paths)
tools/node-t3d-metadata/local.config.json

# One-time tool outputs: regenerable reports, not committed. Written next to the
# tool when you run node discovery / build-db-candidates.
tools/node-t3d-metadata/node-discovery.json
tools/node-t3d-metadata/db-candidates.json

# UE editor-host scratch generated while running commandlets. Keep the committed
# minimal host .uproject (tools/node-t3d-metadata/host/), drop everything UE regenerates.
**/Saved/
**/Intermediate/
**/DerivedDataCache/
