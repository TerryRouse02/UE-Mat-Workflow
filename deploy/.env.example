# Copy to deploy/.env and edit. docker-compose.prod.yml + update.sh read it.

# Your domain (A record must point at this VPS). Caddy issues a cert for it.
VIEWER_DOMAIN=mat.example.com

# Which image tag to run. Default "latest" follows main. Pin a sha- tag to
# freeze a known-good build or to roll back:
#   IMAGE_TAG=sha-abc1234
IMAGE_TAG=latest

# Override the image repo only if you forked / renamed (default is the GHCR repo
# the deploy workflow pushes to).
# VIEWER_IMAGE=ghcr.io/terryrouse02/ue-mat-workflow
