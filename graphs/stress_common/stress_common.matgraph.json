{
  "schemaVersion": "1.0",
  "ueVersion": "5.7",
  "type": "Material",
  "name": "stress_common",
  "description": "Paste-safe stress material: a broad set of common, stable authoring nodes (constants, params, texturing, math, vector ops, utility inputs) wired into a single MaterialOutput. Contains NO MaterialFunctionCall and none of the exotic node families, so it can be exported and pasted into UE 5.7 without crashing.",
  "nodes": [
    { "id": "uv",        "type": "TextureCoordinate", "params": { "UTiling": 2.0, "VTiling": 2.0 } },
    { "id": "time",      "type": "Time" },
    { "id": "panner",    "type": "Panner", "params": { "SpeedX": 0.1, "SpeedY": 0.05 } },

    { "id": "albedoTex", "type": "TextureSampleParameter2D", "params": { "ParameterName": "BaseColorMap", "SamplerType": "Color" } },
    { "id": "detailTex", "type": "TextureSample", "params": { "SamplerType": "LinearColor" } },
    { "id": "normalTex", "type": "TextureSampleParameter2D", "params": { "ParameterName": "NormalMap", "SamplerType": "Normal" } },

    { "id": "tint",      "type": "VectorParameter", "params": { "ParameterName": "Tint", "DefaultValue": [1.0, 0.95, 0.9, 1.0] } },
    { "id": "white",     "type": "Constant3Vector", "params": { "R": 1.0, "G": 1.0, "B": 1.0 } },
    { "id": "halfGray",  "type": "Constant", "params": { "R": 0.5 } },
    { "id": "uvScale",   "type": "Constant2Vector", "params": { "R": 1.0, "G": 1.0 } },
    { "id": "rgbaConst", "type": "Constant4Vector", "params": { "R": 0.2, "G": 0.3, "B": 0.4, "A": 1.0 } },
    { "id": "roughParam","type": "ScalarParameter", "params": { "ParameterName": "Roughness", "DefaultValue": 0.5 } },
    { "id": "metalParam","type": "ScalarParameter", "params": { "ParameterName": "Metallic", "DefaultValue": 0.0 } },
    { "id": "emissPow",  "type": "ScalarParameter", "params": { "ParameterName": "EmissivePower", "DefaultValue": 2.0 } },

    { "id": "vcol",      "type": "VertexColor" },
    { "id": "fresnel",   "type": "Fresnel", "params": { "Exponent": 4.0 } },
    { "id": "camVec",    "type": "CameraVectorWS" },
    { "id": "pixNorm",   "type": "PixelNormalWS" },
    { "id": "worldPos",  "type": "WorldPosition" },

    { "id": "mulTint",   "type": "Multiply" },
    { "id": "addDetail", "type": "Add" },
    { "id": "subOff",    "type": "Subtract", "params": { "ConstB": 0.5 } },
    { "id": "divNorm",   "type": "Divide", "params": { "ConstB": 2.0 } },
    { "id": "oneMinus",  "type": "OneMinus" },
    { "id": "powNode",   "type": "Power" },
    { "id": "absNode",   "type": "Abs" },
    { "id": "fracNode",  "type": "Frac" },
    { "id": "floorNode", "type": "Floor" },
    { "id": "minNode",   "type": "Min", "params": { "ConstB": 1.0 } },
    { "id": "maxNode",   "type": "Max", "params": { "ConstB": 0.0 } },
    { "id": "clampNode", "type": "Clamp" },
    { "id": "satNode",   "type": "Saturate" },
    { "id": "lerpColor", "type": "Lerp" },
    { "id": "sineNode",  "type": "Sine" },
    { "id": "cosNode",   "type": "Cosine" },
    { "id": "sqrtNode",  "type": "SquareRoot" },
    { "id": "stepNode",  "type": "Step" },
    { "id": "smoothNode","type": "SmoothStep" },

    { "id": "mask",      "type": "ComponentMask", "params": { "R": true, "G": true, "B": false, "A": false } },
    { "id": "append",    "type": "AppendVector" },
    { "id": "normalize", "type": "Normalize" },
    { "id": "dot",       "type": "DotProduct" },
    { "id": "cross",     "type": "CrossProduct" },
    { "id": "length",    "type": "Length" },
    { "id": "distance",  "type": "Distance" },
    { "id": "desat",     "type": "Desaturation", "params": { "LuminanceFactors": [0.3, 0.59, 0.11] } },

    { "id": "OUT",       "type": "MaterialOutput" }
  ],
  "connections": [
    { "from": "uv:UVs",            "to": "mask:Input" },
    { "from": "uv:UVs",            "to": "panner:Coordinate" },
    { "from": "time:Value",        "to": "panner:Time" },
    { "from": "panner:UVs",        "to": "albedoTex:UVs" },
    { "from": "uv:UVs",            "to": "detailTex:UVs" },
    { "from": "uv:UVs",            "to": "normalTex:UVs" },

    { "from": "albedoTex:RGB",     "to": "mulTint:A" },
    { "from": "tint:RGB",          "to": "mulTint:B" },
    { "from": "detailTex:RGB",     "to": "addDetail:A" },
    { "from": "mulTint:Result",    "to": "addDetail:B" },
    { "from": "white:RGB",         "to": "lerpColor:A" },
    { "from": "addDetail:Result",  "to": "lerpColor:B" },
    { "from": "vcol:R",            "to": "lerpColor:Alpha" },
    { "from": "lerpColor:Result",  "to": "desat:Input" },
    { "from": "fresnel:Result",    "to": "desat:Fraction" },
    { "from": "desat:Result",      "to": "OUT:BaseColor" },

    { "from": "roughParam:Value",  "to": "oneMinus:Input" },
    { "from": "oneMinus:Result",   "to": "powNode:Base" },
    { "from": "halfGray:Value",    "to": "powNode:Exp" },
    { "from": "powNode:Result",    "to": "absNode:Input" },
    { "from": "absNode:Result",    "to": "fracNode:Input" },
    { "from": "fracNode:Result",   "to": "minNode:A" },
    { "from": "minNode:Result",    "to": "maxNode:A" },
    { "from": "maxNode:Result",    "to": "clampNode:Input" },
    { "from": "clampNode:Result",  "to": "satNode:Input" },
    { "from": "satNode:Result",    "to": "OUT:Roughness" },

    { "from": "metalParam:Value",  "to": "stepNode:X" },
    { "from": "halfGray:Value",    "to": "stepNode:Y" },
    { "from": "stepNode:Result",   "to": "floorNode:Input" },
    { "from": "floorNode:Result",  "to": "OUT:Metallic" },

    { "from": "normalTex:RGB",     "to": "normalize:VectorInput" },
    { "from": "normalize:Result",  "to": "OUT:Normal" },

    { "from": "camVec:XYZ",        "to": "dot:A" },
    { "from": "pixNorm:XYZ",       "to": "dot:B" },
    { "from": "camVec:XYZ",        "to": "cross:A" },
    { "from": "pixNorm:XYZ",       "to": "cross:B" },
    { "from": "cross:Result",      "to": "length:Input" },
    { "from": "worldPos:XYZ",      "to": "distance:A" },
    { "from": "camVec:XYZ",        "to": "distance:B" },

    { "from": "dot:Result",        "to": "sineNode:Input" },
    { "from": "distance:Result",   "to": "cosNode:Input" },
    { "from": "length:Result",     "to": "sqrtNode:Input" },
    { "from": "sineNode:Result",   "to": "smoothNode:Min" },
    { "from": "cosNode:Result",    "to": "smoothNode:Max" },
    { "from": "sqrtNode:Result",   "to": "smoothNode:Value" },

    { "from": "emissPow:Value",    "to": "subOff:A" },
    { "from": "smoothNode:Result", "to": "subOff:B" },
    { "from": "subOff:Result",     "to": "divNorm:A" },
    { "from": "divNorm:Result",    "to": "OUT:EmissiveColor" },

    { "from": "mask:Result",       "to": "append:A" },
    { "from": "rgbaConst:A",       "to": "append:B" },
    { "from": "append:Result",     "to": "OUT:AmbientOcclusion" }
  ],
  "comments": [
    { "id": "c_tex",  "text": "Texturing: UVs, panner, samples", "color": "#4a90e2", "contains": ["uv", "time", "panner", "albedoTex", "detailTex", "normalTex"] },
    { "id": "c_base", "text": "Base Color: tint, blend, desaturate", "color": "#7ed321", "contains": ["tint", "white", "mulTint", "addDetail", "lerpColor", "desat", "vcol", "fresnel"] },
    { "id": "c_rough","text": "Roughness / Metallic math", "color": "#f5a623", "contains": ["roughParam", "metalParam", "oneMinus", "powNode", "absNode", "fracNode", "minNode", "maxNode", "clampNode", "satNode", "stepNode", "floorNode", "halfGray"] },
    { "id": "c_vec",  "text": "Vector ops + utility inputs", "color": "#bd10e0", "contains": ["camVec", "pixNorm", "worldPos", "dot", "cross", "length", "distance", "sineNode", "cosNode", "sqrtNode", "smoothNode", "mask", "append", "normalize", "normalTex"] }
  ]
}
