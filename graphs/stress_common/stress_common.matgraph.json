{
  "schemaVersion": "1.0",
  "ueVersion": "5.7",
  "type": "Material",
  "name": "stress_common",
  "description": "Paste-safe stress material: a broad set of common, stable authoring nodes (constants, params, texturing, math, vector ops, utility inputs) wired into a single MaterialOutput. Contains NO MaterialFunctionCall and none of the exotic node families, so it can be exported and pasted into UE 5.7 without crashing.",
  "nodes": [
    {
      "id": "uv",
      "type": "TextureCoordinate",
      "params": {
        "UTiling": 2,
        "VTiling": 2
      }
    },
    {
      "id": "time",
      "type": "Time"
    },
    {
      "id": "panner",
      "type": "Panner",
      "params": {
        "SpeedX": 0.1,
        "SpeedY": 0.05
      }
    },
    {
      "id": "albedoTex",
      "type": "TextureSampleParameter2D",
      "params": {
        "ParameterName": "BaseColorMap",
        "SamplerType": "Color"
      }
    },
    {
      "id": "detailTex",
      "type": "TextureSample",
      "params": {
        "SamplerType": "LinearColor"
      }
    },
    {
      "id": "normalTex",
      "type": "TextureSampleParameter2D",
      "params": {
        "ParameterName": "NormalMap",
        "SamplerType": "Normal"
      }
    },
    {
      "id": "tint",
      "type": "VectorParameter",
      "params": {
        "ParameterName": "Tint",
        "DefaultValue": [
          1,
          0.95,
          0.9,
          1
        ]
      }
    },
    {
      "id": "white",
      "type": "Constant3Vector",
      "params": {
        "R": 1,
        "G": 1,
        "B": 1
      }
    },
    {
      "id": "halfGray",
      "type": "Constant",
      "params": {
        "R": 0.5
      }
    },
    {
      "id": "uvScale",
      "type": "Constant2Vector",
      "params": {
        "R": 1,
        "G": 1
      }
    },
    {
      "id": "rgbaConst",
      "type": "Constant4Vector",
      "params": {
        "R": 0.2,
        "G": 0.3,
        "B": 0.4,
        "A": 1
      }
    },
    {
      "id": "roughParam",
      "type": "ScalarParameter",
      "params": {
        "ParameterName": "Roughness",
        "DefaultValue": 0.5
      }
    },
    {
      "id": "metalParam",
      "type": "ScalarParameter",
      "params": {
        "ParameterName": "Metallic",
        "DefaultValue": 0
      }
    },
    {
      "id": "emissPow",
      "type": "ScalarParameter",
      "params": {
        "ParameterName": "EmissivePower",
        "DefaultValue": 2
      }
    },
    {
      "id": "vcol",
      "type": "VertexColor"
    },
    {
      "id": "fresnel",
      "type": "Fresnel",
      "params": {
        "Exponent": 4
      }
    },
    {
      "id": "camVec",
      "type": "CameraVectorWS"
    },
    {
      "id": "pixNorm",
      "type": "PixelNormalWS"
    },
    {
      "id": "worldPos",
      "type": "WorldPosition"
    },
    {
      "id": "mulTint",
      "type": "Multiply"
    },
    {
      "id": "addDetail",
      "type": "Add"
    },
    {
      "id": "subOff",
      "type": "Subtract",
      "params": {
        "ConstB": 0.5
      }
    },
    {
      "id": "divNorm",
      "type": "Divide",
      "params": {
        "ConstB": 2
      }
    },
    {
      "id": "oneMinus",
      "type": "OneMinus"
    },
    {
      "id": "powNode",
      "type": "Power"
    },
    {
      "id": "absNode",
      "type": "Abs"
    },
    {
      "id": "fracNode",
      "type": "Frac"
    },
    {
      "id": "floorNode",
      "type": "Floor"
    },
    {
      "id": "minNode",
      "type": "Min",
      "params": {
        "ConstB": 1
      }
    },
    {
      "id": "maxNode",
      "type": "Max",
      "params": {
        "ConstB": 0
      }
    },
    {
      "id": "clampNode",
      "type": "Clamp"
    },
    {
      "id": "satNode",
      "type": "Saturate"
    },
    {
      "id": "lerpColor",
      "type": "Lerp"
    },
    {
      "id": "sineNode",
      "type": "Sine"
    },
    {
      "id": "cosNode",
      "type": "Cosine"
    },
    {
      "id": "sqrtNode",
      "type": "SquareRoot"
    },
    {
      "id": "stepNode",
      "type": "Step"
    },
    {
      "id": "smoothNode",
      "type": "SmoothStep"
    },
    {
      "id": "mask",
      "type": "ComponentMask",
      "params": {
        "R": true,
        "G": false,
        "B": false,
        "A": false
      }
    },
    {
      "id": "append",
      "type": "AppendVector"
    },
    {
      "id": "normalize",
      "type": "Normalize"
    },
    {
      "id": "dot",
      "type": "DotProduct"
    },
    {
      "id": "cross",
      "type": "CrossProduct"
    },
    {
      "id": "length",
      "type": "Length"
    },
    {
      "id": "distance",
      "type": "Distance"
    },
    {
      "id": "desat",
      "type": "Desaturation",
      "params": {
        "LuminanceFactors": [
          0.3,
          0.59,
          0.11
        ]
      }
    },
    {
      "id": "OUT",
      "type": "MaterialOutput"
    },
    {
      "id": "uvScaleMul",
      "type": "Multiply"
    }
  ],
  "connections": [
    {
      "from": "uv:UVs",
      "to": "mask:Input"
    },
    {
      "from": "uv:UVs",
      "to": "panner:Coordinate"
    },
    {
      "from": "time:Value",
      "to": "panner:Time"
    },
    {
      "from": "panner:UVs",
      "to": "albedoTex:UVs"
    },
    {
      "from": "uv:UVs",
      "to": "normalTex:UVs"
    },
    {
      "from": "albedoTex:RGB",
      "to": "mulTint:A"
    },
    {
      "from": "tint:RGB",
      "to": "mulTint:B"
    },
    {
      "from": "detailTex:RGB",
      "to": "addDetail:A"
    },
    {
      "from": "mulTint:Result",
      "to": "addDetail:B"
    },
    {
      "from": "white:RGB",
      "to": "lerpColor:A"
    },
    {
      "from": "addDetail:Result",
      "to": "lerpColor:B"
    },
    {
      "from": "vcol:R",
      "to": "lerpColor:Alpha"
    },
    {
      "from": "lerpColor:Result",
      "to": "desat:Input"
    },
    {
      "from": "fresnel:Result",
      "to": "desat:Fraction"
    },
    {
      "from": "desat:Result",
      "to": "OUT:BaseColor"
    },
    {
      "from": "roughParam:Value",
      "to": "oneMinus:Input"
    },
    {
      "from": "oneMinus:Result",
      "to": "powNode:Base"
    },
    {
      "from": "halfGray:Value",
      "to": "powNode:Exp"
    },
    {
      "from": "powNode:Result",
      "to": "absNode:Input"
    },
    {
      "from": "absNode:Result",
      "to": "fracNode:Input"
    },
    {
      "from": "fracNode:Result",
      "to": "minNode:A"
    },
    {
      "from": "minNode:Result",
      "to": "maxNode:A"
    },
    {
      "from": "maxNode:Result",
      "to": "clampNode:Input"
    },
    {
      "from": "clampNode:Result",
      "to": "satNode:Input"
    },
    {
      "from": "satNode:Result",
      "to": "OUT:Roughness"
    },
    {
      "from": "metalParam:Value",
      "to": "stepNode:X"
    },
    {
      "from": "halfGray:Value",
      "to": "stepNode:Y"
    },
    {
      "from": "stepNode:Result",
      "to": "floorNode:Input"
    },
    {
      "from": "floorNode:Result",
      "to": "OUT:Metallic"
    },
    {
      "from": "normalTex:RGB",
      "to": "normalize:VectorInput"
    },
    {
      "from": "normalize:Result",
      "to": "OUT:Normal"
    },
    {
      "from": "camVec:XYZ",
      "to": "dot:A"
    },
    {
      "from": "pixNorm:XYZ",
      "to": "dot:B"
    },
    {
      "from": "camVec:XYZ",
      "to": "cross:A"
    },
    {
      "from": "pixNorm:XYZ",
      "to": "cross:B"
    },
    {
      "from": "cross:Result",
      "to": "length:Input"
    },
    {
      "from": "worldPos:XYZ",
      "to": "distance:A"
    },
    {
      "from": "camVec:XYZ",
      "to": "distance:B"
    },
    {
      "from": "dot:Result",
      "to": "sineNode:Input"
    },
    {
      "from": "distance:Result",
      "to": "cosNode:Input"
    },
    {
      "from": "length:Result",
      "to": "sqrtNode:Input"
    },
    {
      "from": "sineNode:Result",
      "to": "smoothNode:Min"
    },
    {
      "from": "cosNode:Result",
      "to": "smoothNode:Max"
    },
    {
      "from": "sqrtNode:Result",
      "to": "smoothNode:Value"
    },
    {
      "from": "emissPow:Value",
      "to": "subOff:A"
    },
    {
      "from": "smoothNode:Result",
      "to": "subOff:B"
    },
    {
      "from": "subOff:Result",
      "to": "divNorm:A"
    },
    {
      "from": "divNorm:Result",
      "to": "OUT:EmissiveColor"
    },
    {
      "from": "mask:Result",
      "to": "append:A"
    },
    {
      "from": "rgbaConst:A",
      "to": "append:B"
    },
    {
      "from": "append:Result",
      "to": "OUT:AmbientOcclusion"
    },
    {
      "from": "uv:UVs",
      "to": "uvScaleMul:A"
    },
    {
      "from": "uvScale:RG",
      "to": "uvScaleMul:B"
    },
    {
      "from": "uvScaleMul:Result",
      "to": "detailTex:UVs"
    }
  ],
  "comments": [
    {
      "id": "c_uv_tex",
      "text": "UV & Texturing",
      "color": "#4a90e2",
      "contains": [
        "uv",
        "time",
        "panner",
        "albedoTex",
        "detailTex",
        "normalTex",
        "uvScale",
        "uvScaleMul"
      ]
    },
    {
      "id": "c_base",
      "text": "Base Color & Fresnel",
      "color": "#7ed321",
      "contains": [
        "tint",
        "white",
        "rgbaConst",
        "mulTint",
        "addDetail",
        "lerpColor",
        "desat",
        "vcol",
        "fresnel"
      ]
    },
    {
      "id": "c_rough_metal",
      "text": "Roughness & Metallic",
      "color": "#f5a623",
      "contains": [
        "roughParam",
        "metalParam",
        "oneMinus",
        "powNode",
        "absNode",
        "fracNode",
        "minNode",
        "maxNode",
        "clampNode",
        "satNode",
        "stepNode",
        "floorNode",
        "halfGray"
      ]
    },
    {
      "id": "c_vec_emiss_ao",
      "text": "Vectors, Emissive & AO",
      "color": "#bd10e0",
      "contains": [
        "camVec",
        "pixNorm",
        "worldPos",
        "dot",
        "cross",
        "length",
        "distance",
        "sineNode",
        "cosNode",
        "sqrtNode",
        "smoothNode",
        "emissPow",
        "subOff",
        "divNorm",
        "mask",
        "append",
        "normalize"
      ]
    },
    {
      "id": "c_out",
      "text": "Material Output",
      "color": "#9b9b9b",
      "contains": [
        "OUT"
      ]
    }
  ]
}
